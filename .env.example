# Copy this to .env.local and fill in your values

# PostgreSQL — get from neon.tech (free)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/nexstock?sslmode=require"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Change to your domain in production
NEXTAUTH_URL="http://localhost:3000"

# Optional — AfricasTalking for SMS (africastalking.com)
AT_API_KEY=""
AT_USERNAME=""

# Optional — Flutterwave for payments (flutterwave.com)
FLW_PUBLIC_KEY=""
FLW_SECRET_KEY=""
